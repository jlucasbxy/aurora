// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
}

datasource db {
  provider   = "postgresql"
}

model Invoice {
  id                        String   @id
  clientNumber              String
  referenceMonth            String
  electricEnergyQty         Int
  electricEnergyValue       Decimal  @db.Decimal(15, 2)
  sceeEnergyQty             Int
  sceeEnergyValue           Decimal  @db.Decimal(15, 2)
  compensatedEnergyQty      Int
  compensatedEnergyValue    Decimal  @db.Decimal(15, 2)
  publicLightingContrib     Decimal  @db.Decimal(15, 2)
  electricEnergyConsumption Int
  compensatedEnergy         Int
  totalValueWithoutGD       Decimal  @db.Decimal(15, 2)
  gdSavings                 Decimal  @db.Decimal(15, 2)
  createdAt                 DateTime

  @@index([clientNumber])
  @@index([clientNumber, referenceMonth])
  @@index([referenceMonth])
}
