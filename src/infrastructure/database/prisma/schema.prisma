// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
}

datasource db {
  provider   = "postgresql"
}

model Invoice {
  id                          String   @id
  numeroCliente               String
  mesReferencia               String
  energiaEletricaQtd          Int
  energiaEletricaValor        Decimal
  energiaSCEEsICMSQtd         Int
  energiaSCEEsICMSValor       Decimal
  energiaCompensadaGDIQtd     Int
  energiaCompensadaGDIValor   Decimal
  contribIlumPublicaMunicipal Decimal
  consumoEnergiaEletrica      Int
  energiaCompensada           Int
  valorTotalSemGD             Decimal
  economiaGD                  Decimal
  createdAt                   DateTime

  @@index([numeroCliente])
  @@index([mesReferencia])
}
