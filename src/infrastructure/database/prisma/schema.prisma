// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
}

datasource db {
  provider   = "postgresql"
}

model Invoice {
  id                        String   @id
  clientNumber              String
  referenceMonth            String
  electricEnergyQty         Int
  electricEnergyValue       Decimal
  sceeEnergyQty             Int
  sceeEnergyValue           Decimal
  compensatedEnergyQty      Int
  compensatedEnergyValue    Decimal
  publicLightingContrib     Decimal
  electricEnergyConsumption Int
  compensatedEnergy         Int
  totalValueWithoutGD       Decimal
  gdSavings                 Decimal
  createdAt                 DateTime

  @@index([clientNumber])
  @@index([referenceMonth])
}
