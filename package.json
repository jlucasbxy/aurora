    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.19.7",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
